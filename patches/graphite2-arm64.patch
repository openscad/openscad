Fix SSE2 flags being applied to arm64 macOS builds.

When building on a machine where the cmake binary is x86_64 (e.g. under
Rosetta 2), CMAKE_SYSTEM_PROCESSOR reports as x86_64, causing the x86-only
-mfpmath=sse -msse2 flags to be added even when CMAKE_OSX_ARCHITECTURES
targets arm64. Guard the flags with an explicit arm64 architecture check.

--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -139,7 +139,7 @@
         COMPILE_FLAGS   "-Wall -Wextra -Wno-unknown-pragmas -Wimplicit-fallthrough -Wendif-labels -Wshadow -Wno-ctor-dtor-privacy -Wno-non-virtual-dtor -fno-rtti -fno-exceptions -fvisibility=hidden -fvisibility-inlines-hidden"
         LINK_FLAGS      "-nodefaultlibs"
         LINKER_LANGUAGE C)
-    if (${CMAKE_SYSTEM_PROCESSOR} MATCHES "x86|i.86")
+    if (${CMAKE_SYSTEM_PROCESSOR} MATCHES "x86|i.86" AND NOT CMAKE_OSX_ARCHITECTURES MATCHES "arm64")
         add_definitions(-mfpmath=sse -msse2)
     endif()
     target_link_libraries(graphite2 c)
