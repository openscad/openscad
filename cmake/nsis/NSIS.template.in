;Installer Sections

Section "-Core installation"
  ;Use the entire tree produced by the INSTALL target.  Keep the
  ;list of directories here in sync with the RMDir commands below.
  SetOutPath "$INSTDIR"
  @CPACK_NSIS_EXTRA_PREINSTALL_COMMANDS@
  @CPACK_NSIS_FULL_INSTALL@

  ;Store installation folder
  WriteRegStr SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@" "" $INSTDIR

  ;Create uninstaller
  WriteUninstaller "$INSTDIR\@CPACK_NSIS_UNINSTALL_NAME@.exe"
  Push "DisplayName"
  ${If} $InstallMode = 1
    Push "@CPACK_NSIS_DISPLAY_NAME@ (all users)"
  ${Else}
    Push "@CPACK_NSIS_DISPLAY_NAME@ (current user)"
  ${EndIf}
  Call ConditionalAddToRegistry
  Push "DisplayVersion"
  Push "@CPACK_PACKAGE_VERSION@"
  Call ConditionalAddToRegistry
  Push "Publisher"
  Push "@CPACK_PACKAGE_VENDOR@"
  Call ConditionalAddToRegistry
  Push "UninstallString"
  Push "$\"$INSTDIR\@CPACK_NSIS_UNINSTALL_NAME@.exe$\""
  Call ConditionalAddToRegistry
  Push "NoRepair"
  Push "1"
  Call ConditionalAddToRegistry

  !ifdef CPACK_NSIS_ADD_REMOVE
  ;Create add/remove functionality
  Push "ModifyPath"
  Push "$INSTDIR\AddRemove.exe"
  Call ConditionalAddToRegistry
  !else
  Push "NoModify"
  Push "1"
  Call ConditionalAddToRegistry
  !endif

  ; Optional registration
  Push "DisplayIcon"
  Push "$INSTDIR\@CPACK_NSIS_INSTALLED_ICON_NAME@"
  Call ConditionalAddToRegistry
  Push "HelpLink"
  Push "@CPACK_NSIS_HELP_LINK@"
  Call ConditionalAddToRegistry
  Push "URLInfoAbout"
  Push "@CPACK_NSIS_URL_INFO_ABOUT@"
  Call ConditionalAddToRegistry
  Push "Contact"
  Push "@CPACK_NSIS_CONTACT@"
  Call ConditionalAddToRegistry
  ; Custom InstallOptions.ini (cmake/nsis/NSIS.InstallOptions.ini.in) has 3 fields:
  ;   Field 1: label
  ;   Field 2: "Add to PATH" checkbox (1 = add, 0 = skip)
  ;   Field 3: "Create Desktop Icon" checkbox
  ; PATH scope is derived from $InstallMode, so the user is not asked
  ; about all-users vs current-user PATH separately.
  !insertmacro MUI_INSTALLOPTIONS_READ $ADD_TO_PATH_CURRENT_USER "NSIS.InstallOptions.ini" "Field 2" "State"
  !insertmacro MUI_INSTALLOPTIONS_READ $INSTALL_DESKTOP "NSIS.InstallOptions.ini" "Field 3" "State"

  ; Translate the single checkbox into the legacy three-variable PATH state used
  ; by the AddToPath/RemoveFromPath helpers below.
  ${If} $ADD_TO_PATH_CURRENT_USER = 0
    StrCpy $DO_NOT_ADD_TO_PATH 1
    StrCpy $ADD_TO_PATH_ALL_USERS 0
    StrCpy $ADD_TO_PATH_CURRENT_USER 0
  ${ElseIf} $InstallMode = 1
    StrCpy $DO_NOT_ADD_TO_PATH 0
    StrCpy $ADD_TO_PATH_ALL_USERS 1
    StrCpy $ADD_TO_PATH_CURRENT_USER 0
  ${Else}
    StrCpy $DO_NOT_ADD_TO_PATH 0
    StrCpy $ADD_TO_PATH_ALL_USERS 0
    StrCpy $ADD_TO_PATH_CURRENT_USER 1
  ${EndIf}

  !insertmacro MUI_STARTMENU_WRITE_BEGIN Application

  ;Create shortcuts
  CreateDirectory "$SMPROGRAMS\$STARTMENU_FOLDER"
@CPACK_NSIS_CREATE_ICONS@
@CPACK_NSIS_CREATE_ICONS_EXTRA@
  CreateShortCut "$SMPROGRAMS\$STARTMENU_FOLDER\Uninstall.lnk" "$INSTDIR\@CPACK_NSIS_UNINSTALL_NAME@.exe"

  ; Write special uninstall registry entries
  Push "StartMenu"
  Push "$STARTMENU_FOLDER"
  Call ConditionalAddToRegistry
  Push "DoNotAddToPath"
  Push "$DO_NOT_ADD_TO_PATH"
  Call ConditionalAddToRegistry
  Push "AddToPathAllUsers"
  Push "$ADD_TO_PATH_ALL_USERS"
  Call ConditionalAddToRegistry
  Push "AddToPathCurrentUser"
  Push "$ADD_TO_PATH_CURRENT_USER"
  Call ConditionalAddToRegistry
  Push "InstallToDesktop"
  Push "$INSTALL_DESKTOP"
  Call ConditionalAddToRegistry

  !insertmacro MUI_STARTMENU_WRITE_END

@CPACK_NSIS_EXTRA_INSTALL_COMMANDS@

  ; Create desktop shortcut if requested
  StrCmp $INSTALL_DESKTOP "1" 0 skip_desktop_install
    CreateShortCut "$DESKTOP\@CPACK_NSIS_PACKAGE_NAME@.lnk" "$INSTDIR\@CPACK_NSIS_INSTALLED_ICON_NAME@"
  skip_desktop_install:

SectionEnd

Section "-Add to path"
  ; PythonSCAD installs pythonscad.exe directly under $INSTDIR (not $INSTDIR\bin).
  Push $INSTDIR
  StrCmp "@CPACK_NSIS_MODIFY_PATH@" "ON" 0 doNotAddToPath
  StrCmp $DO_NOT_ADD_TO_PATH "1" doNotAddToPath 0
    Call AddToPath
  doNotAddToPath:
SectionEnd

;--------------------------------
; Install-mode page: "Just for me" vs "For all users"
; The "For all users" path re-launches the installer elevated via ShellExecuteEx
; with the runas verb, then quits the non-elevated instance.

Function InstallModePage_OnClick
  Pop $1
  nsDialogs::GetUserData $1
  Pop $1
  ; Show UAC shield only when "All users" is selected and elevation is still needed.
  ${If} $1 = 1
    !insertmacro IsElevated $2
    ${If} $2 = 1
      StrCpy $1 0
    ${EndIf}
  ${EndIf}
  GetDlgItem $0 $HWNDParent 1
  SendMessage $0 ${BCM_SETSHIELD} 0 $1
FunctionEnd

; Used as MUI_PAGE_CUSTOMFUNCTION_PRE on Welcome and License to skip those
; pages when we are the elevated re-launch and .onInit verified actual
; elevation (so $InstallMode = 1). On the unelevated outer instance, the
; pages display normally. Same skip predicate as InstallModePage_Create.
Function SkipPagesOnElevatedReLaunch
  ${GetOptions} $CMDLINE "/elevated" $R0
  ${IfNot} ${Errors}
    ${If} $InstallMode = 1
      Abort
    ${EndIf}
  ${EndIf}
FunctionEnd

Function InstallModePage_OnBack
  ; Clear the UAC shield from the Next button before leaving the page, otherwise
  ; the shield persists on the License page's "I Agree" button (Next is the same
  ; underlying control across all pages -- only its label changes).
  GetDlgItem $0 $HWNDParent 1
  SendMessage $0 ${BCM_SETSHIELD} 0 0
FunctionEnd

Function InstallModePage_Create
  ; Skip the install-mode page when this is a verified elevated re-launch:
  ; both the /elevated flag must be present AND .onInit must have confirmed
  ; elevation and set $InstallMode = 1. If elevation verification failed,
  ; $InstallMode stays 0 and we show the page normally.
  ${GetOptions} $CMDLINE "/elevated" $R0
  ${IfNot} ${Errors}
    ${If} $InstallMode = 1
      Abort
    ${EndIf}
  ${EndIf}

  !insertmacro MUI_HEADER_TEXT "Installation Type" "Choose how @CPACK_NSIS_PACKAGE_NAME@ should be installed."
  GetFunctionAddress $8 InstallModePage_OnClick
  nsDialogs::Create /NOUNLOAD 1018
  Pop $9
  ${NSD_OnBack} InstallModePage_OnBack

  ${NSD_CreateLabel} 0 10u 100% 20u "Select whether to install @CPACK_NSIS_PACKAGE_NAME@ for yourself only or for all users on this computer."
  Pop $0

  ${NSD_CreateRadioButton} 10u 38u 90% 15u "Just for me (no administrator rights required)"
  Pop $0
  nsDialogs::OnClick $0 $8
  nsDialogs::SetUserData $0 0
  ${IfThen} $InstallMode = 0 ${|} SendMessage $0 ${BM_CLICK} 0 0 ${|}

  ${NSD_CreateRadioButton} 10u 58u 90% 15u "For all users on this computer (requires administrator rights)"
  Pop $AllUsersRadio
  nsDialogs::OnClick $AllUsersRadio $8
  nsDialogs::SetUserData $AllUsersRadio 1
  ${IfThen} $InstallMode = 1 ${|} SendMessage $AllUsersRadio ${BM_CLICK} 0 0 ${|}

  nsDialogs::Show
FunctionEnd

Function InstallModePage_Leave
  ${NSD_GetState} $AllUsersRadio $9
  ${If} $9 = 0
    ; Just for me
    StrCpy $InstallMode 0
    Call SetArpRegKeyFromInstallMode
    StrCpy $INSTDIR "$LOCALAPPDATA\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
    SetShellVarContext current
    ; Clear the shield from the Next button
    GetDlgItem $0 $HWNDParent 1
    SendMessage $0 ${BCM_SETSHIELD} 0 0
    ; If the user switched from the default all-users mode, the .onInit
    ; existing-install check looked only at HKLM. Re-check HKCU now so an
    ; existing per-user install is not silently overwritten.
    ${If} $InitialInstallMode = 1
      Call CheckExistingInstallInteractive
    ${EndIf}
  ${Else}
    ; All users — re-launch elevated if not already running with an elevated token.
    !insertmacro IsElevated $0
    ${If} $0 = 1
      ; Already elevated: just update mode and continue
      StrCpy $InstallMode 1
      Call SetArpRegKeyFromInstallMode
      StrCpy $INSTDIR "$PROGRAMFILES64\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
      StrCmp "@CPACK_SYSTEM_NAME@" "windows-x86-64" +2
        StrCpy $INSTDIR "$PROGRAMFILES\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
      SetShellVarContext all
      ; No UAC prompt will occur in this path, so clear any stale shield.
      GetDlgItem $0 $HWNDParent 1
      SendMessage $0 ${BCM_SETSHIELD} 0 0
      ; If the user switched from per-user to all-users while already elevated,
      ; .onInit only checked HKCU. Re-check HKLM now.
      ${If} $InitialInstallMode = 0
        Call CheckExistingInstallInteractive
      ${EndIf}
    ${Else}
      ; Re-launch elevated via ShellExecuteW runas with /elevated so the
      ; elevated instance skips the mode page and goes straight to all-users.
      ; Do NOT append /elevated to $CMDLINE: NSIS requires /D=<dir> to be the
      ; very last argument, so appending anything after it breaks install-dir
      ; handling. The elevated instance starts fresh and lets the user pick dirs.
      ; The elevated child's .onInit will run the existing-install check
      ; scoped to HKLM, so no additional check is needed in this branch.
      System::Call 'shell32::ShellExecuteW(p $HWNDParent, w "runas", w "$EXEPATH", w "/elevated", p 0, i 1) i.r0'
      ${If} $0 > 32
        Quit
      ${Else}
        ; User cancelled UAC or launch failed — stay on the page
        MessageBox MB_ICONEXCLAMATION "Administrator privileges are required to install for all users.$\nPlease select 'Just for me' or provide administrator credentials."
        Abort
      ${EndIf}
    ${EndIf}
  ${EndIf}
FunctionEnd

; --- CheckExistingInstallInteractive ----------------------------------------
; Re-runs the existing-install detection from .onInit, but at install-mode-page
; Leave time, against the hive matching the current $InstallMode. Used when the
; user switched install mode after .onInit's initial check ran.
;
; Behavior matches the .onInit version: if the matching ARP entry exists, ask
; the user whether to uninstall it first. On Yes, run the old uninstaller
; synchronously. On No, continue. On Cancel, Abort.
Function CheckExistingInstallInteractive
  ${If} $InstallMode = 1
    ReadRegStr $0 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "UninstallString"
    ${If} $0 == ""
      Return
    ${EndIf}
    ReadRegStr $1 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "DisplayName"
  ${Else}
    ReadRegStr $0 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "UninstallString"
    ${If} $0 == ""
      Return
    ${EndIf}
    ReadRegStr $1 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "DisplayName"
  ${EndIf}

  MessageBox MB_YESNOCANCEL|MB_ICONEXCLAMATION \
    "$1 is already installed.$\n$\nDo you want to uninstall the old version before installing the new one?" \
    /SD IDYES IDYES interactive_uninst IDNO interactive_skip
  Abort

interactive_uninst:
  ; Strip surrounding quotes if present (matches the .onInit logic).
  StrCpy $2 $0 1 0
  StrCmp $2 "$\"" 0 +2
  StrCpy $0 $0 "" 1
  StrCpy $2 $0 1 -1
  StrCmp $2 "$\"" 0 +2
  StrCpy $0 $0 -1

  ; Run the old uninstaller WITHOUT /S and WITHOUT _?= — see the .onInit uninst
  ; block for the full explanation.  Pass /frominstaller so PythonSCAD
  ; uninstallers built from this template skip their own confirm page.
  ClearErrors
  ExecWait '"$0" /frominstaller' $1
  IfErrors interactive_uninst_failed
  ${If} $1 != 0
    Goto interactive_uninst_failed
  ${EndIf}
  Return

interactive_uninst_failed:
  MessageBox MB_OK|MB_ICONSTOP "Uninstall failed."
  Abort

interactive_skip:
  Return
FunctionEnd

;--------------------------------
; Create custom pages
Function InstallOptionsPage
  !insertmacro MUI_HEADER_TEXT "Install Options" "Choose options for installing @CPACK_NSIS_PACKAGE_NAME@"
  ; On the elevated re-launch, this is the first interactive page and the
  ; preceding pages (Welcome, License, install-mode) have all been skipped
  ; via Abort in their PRE functions. The Back button cannot lead anywhere
  ; useful in that scenario -- every earlier page would Abort, eventually
  ; closing the installer entirely. Hide it so the user is not surprised
  ; by Back-quitting-the-installer behaviour.
  ClearErrors
  ${GetOptions} $CMDLINE "/elevated" $R0
  ${IfNot} ${Errors}
    GetDlgItem $0 $HWNDParent 3
    ShowWindow $0 ${SW_HIDE}
  ${EndIf}
  !insertmacro MUI_INSTALLOPTIONS_DISPLAY "NSIS.InstallOptions.ini"
FunctionEnd

; Called as MUI_UNPAGE_CONFIRM PRE function: skip the confirmation page when
; the uninstaller was launched by a PythonSCAD installer (user already confirmed).
Function un.SkipConfirmIfCalledByInstaller
  ${If} $UninstalledByInstaller = 1
    Abort
  ${EndIf}
FunctionEnd

;--------------------------------
; Uninstall init: read the InstallMode value written to the ARP key at install
; time to determine scope. Both InstallMode and InstallLocation are read from
; the ARP key. InstallLocation is cross-checked against $INSTDIR (the directory
; the uninstaller was launched from) to handle the case where both a per-user and
; an all-users install coexist — each uninstaller matches only its own ARP entry.
Function un.onInit
  StrCmp "@CPACK_SYSTEM_NAME@" "windows-x86-64" 0 +2
    SetRegView 64

  ; Detect /frominstaller flag: set by a PythonSCAD installer running us as part
  ; of uninstall-before-upgrade.  The user already confirmed the uninstall there,
  ; so we skip our own confirm page.
  StrCpy $UninstalledByInstaller 0
  ClearErrors
  ${GetOptions} $CMDLINE "/frominstaller" $R0
  ${IfNot} ${Errors}
    StrCpy $UninstalledByInstaller 1
  ${EndIf}

  ; Check HKCU first. Verify InstallLocation matches $INSTDIR so the all-users
  ; uninstaller doesn't accidentally match a per-user entry.
  ; Path comparison uses lstrcmpiW because Windows paths are case-insensitive
  ; but NSIS string comparison is not. $INSTDIR (the directory the uninstaller
  ; was launched from) and the stored InstallLocation can have different casing
  ; depending on the source -- e.g. $LOCALAPPDATA expands via SHGetFolderPath
  ; while a registry round-trip returns the stored string verbatim.
  ; Stage $INSTDIR into $3 so System::Call can reference it via the `w r3`
  ; register source (more explicit than the System plugin's `d` shortcut,
  ; which is less widely recognised by reviewers even though it does map to
  ; $INSTDIR per the plugin source).
  StrCpy $3 $INSTDIR
  ReadRegStr $0 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "InstallMode"
  ${If} $0 == "CurrentUser"
    ReadRegStr $1 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "InstallLocation"
    System::Call 'kernel32::lstrcmpiW(w r1, w r3) i.r2'
    ${If} $2 = 0
      StrCpy $InstallMode 0
      Call un.SetArpRegKeyFromInstallMode
      SetShellVarContext current
      Return
    ${EndIf}
  ${EndIf}

  ; Check HKLM for an all-users install record. Verify InstallLocation matches
  ; $INSTDIR so the per-user uninstaller doesn't match the all-users ARP entry.
  ReadRegStr $0 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "InstallMode"
  ${If} $0 == "AllUsers"
    ReadRegStr $1 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "InstallLocation"
    System::Call 'kernel32::lstrcmpiW(w r1, w r3) i.r2'
    ${If} $2 = 0
      StrCpy $InstallMode 1
      Call un.SetArpRegKeyFromInstallMode
      SetShellVarContext all
      ; All-users install requires an elevated token. Re-launch elevated if needed,
      ; passing the original command line so silent-mode flags (/S _?=...) are
      ; preserved. Use ShellExecuteEx with SEE_MASK_NOCLOSEPROCESS so we can
      ; wait for the elevated process to finish before this instance quits,
      ; preventing the installer from continuing before cleanup is complete.
      !insertmacro IsElevated $2
      ${If} $2 = 0
        ; NSIS ships exclusively as a 32-bit PE even when run on 64-bit Windows,
        ; so sizeof(SHELLEXECUTEINFO) is always 60 bytes here.
        ; SHELLEXECUTEINFO struct layout (60 bytes for 32-bit NSIS):
        ;   cbSize(i), fMask(i), hwnd(i), lpVerb(w), lpFile(w), lpParameters(w),
        ;   lpDirectory(w), nShow(i), hInstApp(i), lpIDList(i), lpClass(w),
        ;   hkeyClass(i), dwHotKey(i), hIcon/hMonitor(i), hProcess(i)
        ; fMask = SEE_MASK_NOCLOSEPROCESS(0x40) | SEE_MASK_NO_CONSOLE(0x8000) = 0x8040
        System::Alloc 60
        Pop $3
        System::Call "*$3(i 60, i 0x8040, i $HWNDParent, w 'runas', w '$EXEPATH', \
          w '$CMDLINE', w '', i 1, i 0, i 0, w '', i 0, i 0, i 0, i 0)"
        System::Call 'shell32::ShellExecuteExW(i r3) i.r2'
        ${If} $2 != 0
          ; Read hProcess from offset 56 (last field at offset 14*4=56)
          ; Last struct field is the hProcess HANDLE: use 'p' (pointer-sized
          ; int), consistent with the IsElevated macro convention.
          System::Call "*$3(i, i, i, w, w, w, w, i, i, i, w, i, i, i, p.r4)"
          System::Call 'kernel32::WaitForSingleObject(p r4, i 0xFFFFFFFF)'
          System::Call 'kernel32::CloseHandle(p r4)'
          System::Free $3
          Quit
        ${Else}
          System::Free $3
          MessageBox MB_ICONSTOP "Administrator privileges are required to uninstall the system-wide installation."
          Abort
        ${EndIf}
      ${EndIf}
      Return
    ${EndIf}
  ${EndIf}

  ; Fallback: default to current user
  StrCpy $InstallMode 0
  Call un.SetArpRegKeyFromInstallMode
  SetShellVarContext current
FunctionEnd

;--- Add/Remove callback functions: ---
!macro SectionList MacroName
  ;This macro used to perform operation on multiple sections.
  ;List all of your components in following manner here.
@CPACK_NSIS_COMPONENT_SECTION_LIST@
!macroend

Section -FinishComponents
  ;Removes unselected components and writes component status to registry
  !insertmacro SectionList "FinishSection"

!ifdef CPACK_NSIS_ADD_REMOVE
  ; Get the name of the installer executable
  System::Call 'kernel32::GetModuleFileNameA(i 0, t .R0, i 1024) i r1'
  StrCpy $R3 $R0

  ; Strip off the last 13 characters, to see if we have AddRemove.exe
  StrLen $R1 $R0
  IntOp $R1 $R0 - 13
  StrCpy $R2 $R0 13 $R1
  StrCmp $R2 "AddRemove.exe" addremove_installed

  ; We're not running AddRemove.exe, so install it
  CopyFiles $R3 $INSTDIR\AddRemove.exe

  addremove_installed:
!endif
SectionEnd
;--- End of Add/Remove callback functions ---

;--------------------------------
; Component dependencies
Function .onSelChange
  !insertmacro SectionList MaybeSelectionChanged
FunctionEnd

;--------------------------------
;Uninstaller Section

Section "Uninstall"
  ReadRegStr $START_MENU SHCTX \
   "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey" "StartMenu"
  ;MessageBox MB_OK "Start menu is in: $START_MENU"
  ReadRegStr $DO_NOT_ADD_TO_PATH SHCTX \
    "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey" "DoNotAddToPath"
  ReadRegStr $ADD_TO_PATH_ALL_USERS SHCTX \
    "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey" "AddToPathAllUsers"
  ReadRegStr $ADD_TO_PATH_CURRENT_USER SHCTX \
    "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey" "AddToPathCurrentUser"
  ;MessageBox MB_OK "Add to path: $DO_NOT_ADD_TO_PATH all users: $ADD_TO_PATH_ALL_USERS"
  ReadRegStr $INSTALL_DESKTOP SHCTX \
    "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey" "InstallToDesktop"

  ; Remove desktop shortcut if it was installed
  StrCmp $INSTALL_DESKTOP "1" 0 skip_desktop_uninstall
    Delete "$DESKTOP\@CPACK_NSIS_PACKAGE_NAME@.lnk"
  skip_desktop_uninstall:

@CPACK_NSIS_EXTRA_UNINSTALL_COMMANDS@

  ;Remove files we installed.
  ;Keep the list of directories here in sync with the File commands above.
@CPACK_NSIS_DELETE_FILES@
@CPACK_NSIS_DELETE_DIRECTORIES@

!ifdef CPACK_NSIS_ADD_REMOVE
  ;Remove the add/remove program
  Delete "$INSTDIR\AddRemove.exe"
!endif

  ;Remove the uninstaller itself.
  Delete "$INSTDIR\@CPACK_NSIS_UNINSTALL_NAME@.exe"
  DeleteRegKey SHCTX "Software\Microsoft\Windows\CurrentVersion\Uninstall\$ArpRegKey"

  ;Remove the installation directory if it is empty.
  RMDir "$INSTDIR"

  ; Remove the registry entries.
  DeleteRegKey SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

  ; Removes all optional components
  !insertmacro SectionList "RemoveSection_CPack"

  !insertmacro MUI_STARTMENU_GETFOLDER Application $MUI_TEMP

  Delete "$SMPROGRAMS\$MUI_TEMP\Uninstall.lnk"
@CPACK_NSIS_DELETE_ICONS@
@CPACK_NSIS_DELETE_ICONS_EXTRA@

  ;Delete empty start menu parent directories
  StrCpy $MUI_TEMP "$SMPROGRAMS\$MUI_TEMP"

  startMenuDeleteLoop:
    ClearErrors
    RMDir $MUI_TEMP
    GetFullPathName $MUI_TEMP "$MUI_TEMP\.."

    IfErrors startMenuDeleteLoopDone

    StrCmp "$MUI_TEMP" "$SMPROGRAMS" startMenuDeleteLoopDone startMenuDeleteLoop
  startMenuDeleteLoopDone:

  ; If the user changed the shortcut, then uninstall may not work. This should
  ; try to fix it.
  StrCpy $MUI_TEMP "$START_MENU"
  Delete "$SMPROGRAMS\$MUI_TEMP\Uninstall.lnk"
@CPACK_NSIS_DELETE_ICONS_EXTRA@

  ;Delete empty start menu parent directories
  StrCpy $MUI_TEMP "$SMPROGRAMS\$MUI_TEMP"

  secondStartMenuDeleteLoop:
    ClearErrors
    RMDir $MUI_TEMP
    GetFullPathName $MUI_TEMP "$MUI_TEMP\.."

    IfErrors secondStartMenuDeleteLoopDone

    StrCmp "$MUI_TEMP" "$SMPROGRAMS" secondStartMenuDeleteLoopDone secondStartMenuDeleteLoop
  secondStartMenuDeleteLoopDone:

  DeleteRegKey /ifempty SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

  Push $INSTDIR
  StrCmp $DO_NOT_ADD_TO_PATH "1" doNotRemoveFromPath 0
    Call un.RemoveFromPath
  doNotRemoveFromPath:
SectionEnd

;--------------------------------
; Initialize install mode and INSTDIR before any pages are shown.

Function .onInit
  ; Use 64-bit registry view on x64 installers so registry reads/writes land
  ; in the native hive rather than Wow6432Node.
  StrCmp "@CPACK_SYSTEM_NAME@" "windows-x86-64" 0 +2
    SetRegView 64

  ; Plugin warmup with user feedback. Without this, the first nsDialogs::Create
  ; (in InstallModePage_Create after the License page) freezes the UI for ~10s
  ; while Windows AppCompat / Defender scans the freshly-extracted nsDialogs.dll.
  ; Banner.dll is tiny (~7.5KB) so its own scan completes near-instantly, and it
  ; runs non-blocking in a separate window — the user sees the "please wait"
  ; message while NSIS extracts and Windows scans nsDialogs.dll in .onInit
  ; rather than at first page transition.
  ; Skip on the /elevated re-launch: the outer instance already triggered the
  ; scan and the cached DLL load in the elevated child is fast.
  ClearErrors
  ${GetOptions} $CMDLINE "/elevated" $R0
  ${If} ${Errors}
    Banner::show /NOUNLOAD "Preparing setup, please wait..."
    ; Throwaway nsDialogs::Create — fails (no parent window in .onInit) but the
    ; DLL-load side effect is what we want. After this returns, nsDialogs.dll is
    ; AV-scanned and cached, so the real Create in InstallModePage_Create is fast.
    nsDialogs::Create /NOUNLOAD 1018
    Pop $0
    Banner::destroy
  ${EndIf}

  ; Default to per-user install. The install-mode page lets the user switch to
  ; all-users, which re-launches this installer elevated via ShellExecuteEx runas
  ; with the /elevated flag. Detect that flag here to pre-select "All users" and
  ; skip straight to all-users mode (the install-mode page is skipped via Abort
  ; in InstallModePage_Create when $InstallMode is already 1 and we are elevated).
  ClearErrors
  ${GetOptions} $CMDLINE "/elevated" $R0
  ${IfNot} ${Errors}
    ; Re-launched elevated instance — verify the process token is actually elevated
    ; so a user cannot bypass to all-users mode by manually passing /elevated.
    !insertmacro IsElevated $R1
    ${If} $R1 = 1
      StrCpy $InstallMode 1
      Call SetArpRegKeyFromInstallMode
      StrCpy $INSTDIR "$PROGRAMFILES64\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
      StrCmp "@CPACK_SYSTEM_NAME@" "windows-x86-64" +2
        StrCpy $INSTDIR "$PROGRAMFILES\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
      SetShellVarContext all
      Goto done_init_mode
    ${EndIf}
    ; Not actually elevated — fall through to normal mode detection below.
  ${EndIf}

  ; Pre-select the install mode based on whether the current process is
  ; actually elevated, NOT just whether the user belongs to the Administrators
  ; group. Under UAC, an admin's normal interactive shell runs with a filtered
  ; (non-elevated) token, so UserInfo::GetAccountType == "Admin" does not mean
  ; we can write to HKLM / Program Files. Defaulting to all-users in that case
  ; would cause silent installs (/S) -- which skip the install-mode page and
  ; therefore the InstallModePage_Leave elevation re-launch -- to attempt HKLM
  ; writes without elevation and fail/install partially. Default to per-user
  ; whenever the token is not elevated; an interactive admin can still switch
  ; to "For all users" on the install-mode page, which triggers the UAC prompt
  ; via the runas re-launch.
  ;
  ; Silent install (/S) behavior matrix:
  ;   Elevated process  -> all-users to $PROGRAMFILES64, no UAC prompt
  ;   Non-elevated      -> per-user to $LOCALAPPDATA, no UAC prompt
  ; Forcing per-user from an elevated context, or forcing all-users from a
  ; non-elevated context, is not currently supported in silent mode -- both
  ; would require additional command-line flags. Interactive installs can
  ; switch freely via the install-mode page (the all-users case re-launches
  ; elevated via the /elevated flag).
  !insertmacro IsElevated $0
  ${If} $0 = 1
    StrCpy $InstallMode 1
    Call SetArpRegKeyFromInstallMode
    StrCpy $INSTDIR "$PROGRAMFILES64\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
    StrCmp "@CPACK_SYSTEM_NAME@" "windows-x86-64" +2
      StrCpy $INSTDIR "$PROGRAMFILES\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
    SetShellVarContext all
  ${Else}
    StrCpy $InstallMode 0
    Call SetArpRegKeyFromInstallMode
    StrCpy $INSTDIR "$LOCALAPPDATA\@CPACK_PACKAGE_INSTALL_DIRECTORY@"
    SetShellVarContext current
  ${EndIf}

  done_init_mode:

  ; Ensure registry helper writes target the scoped uninstall key selected above.
  Call SetArpRegKeyFromInstallMode

  StrCmp "@CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL@" "ON" 0 done_uninst_check

  ; Check for an existing installation in the SAME scope we are about to install
  ; into. The two scopes can coexist (one per-user install + one all-users
  ; install) so we must not prompt to uninstall the per-user copy when the user
  ; is installing all-users (or vice versa). $InstallMode is already set above
  ; (either by /elevated re-launch or by the UserInfo::GetAccountType default).
  ${If} $InstallMode = 1
    ReadRegStr $0 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "UninstallString"
    StrCmp $0 "" done_uninst_check 0
    ReadRegStr $1 HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_ALL_USERS}" "DisplayName"
  ${Else}
    ReadRegStr $0 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "UninstallString"
    StrCmp $0 "" done_uninst_check 0
    ReadRegStr $1 HKCU "Software\Microsoft\Windows\CurrentVersion\Uninstall\${ARP_KEY_CURRENT_USER}" "DisplayName"
  ${EndIf}
  MessageBox MB_YESNOCANCEL|MB_ICONEXCLAMATION \
  "$1 is already installed. $\n$\nDo you want to uninstall the old version before installing the new one?" \
  /SD IDYES IDYES uninst IDNO done_uninst_check
  Abort

;Run the uninstaller
uninst:
  ClearErrors
  # $0 should _always_ be quoted, however older versions of CMake did not
  # do this.  We'll conditionally remove the begin/end quotes.
  # Remove first char if quote
  StrCpy $2 $0 1 0      # copy first char
  StrCmp $2 "$\"" 0 +2  # if char is quote
  StrCpy $0 $0 "" 1     # remove first char
  # Remove last char if quote
  StrCpy $2 $0 1 -1     # copy last char
  StrCmp $2 "$\"" 0 +2  # if char is quote
  StrCpy $0 $0 -1       # remove last char

  ; Run the old uninstaller WITHOUT /S and WITHOUT _?=.
  ; - No /S: the uninstaller shows its own UI (progress bar) so the user has
  ;   visual feedback during the ~10 second removal.  The user already confirmed
  ;   the uninstall by clicking Yes in this installer, so the extra confirm page
  ;   in the old uninstaller is a minor redundancy, not a problem.
  ;   PythonSCAD uninstallers built from this template recognise /frominstaller
  ;   and automatically skip their own confirm page.
  ; - No _?=: using _?= (in-place execution) causes some NSIS uninstallers to
  ;   return exit code 2 and abort without doing anything, because their
  ;   un.onInit path-comparison logic behaves differently when $INSTDIR is set
  ;   from the _?= parameter versus the default temp-copy behaviour.
  ExecWait '"$0" /frominstaller' $1

  IfErrors uninst_failed
  ${If} $1 != 0
    Goto uninst_failed
  ${EndIf}
  Goto done_uninst_check
uninst_failed:
  MessageBox MB_OK|MB_ICONSTOP "Uninstall failed."
  Abort

done_uninst_check:
  ; Snapshot the initial install mode so InstallModePage_Leave can detect when
  ; the user switched modes interactively. The existing-install check above
  ; ran with this mode; if the user changes it on the page, Leave re-runs the
  ; check against the other hive.
  StrCpy $InitialInstallMode $InstallMode

  ; Reads components status for registry
  !insertmacro SectionList "InitSection"

  StrCmp "@CPACK_NSIS_MODIFY_PATH@" "ON" 0 noOptionsPage
    !insertmacro MUI_INSTALLOPTIONS_EXTRACT "NSIS.InstallOptions.ini"

  noOptionsPage:
FunctionEnd
