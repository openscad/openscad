<component type="desktop">
  <id>org.pythonscad.PythonSCAD${SUFFIX_WITH_DASH}</id>
  <metadata_license>CC0-1.0</metadata_license>
  <name>PythonSCAD</name>
  <summary>Design 3D models with Python — script-based CAD with live preview</summary>
  <icon type="remote">https://www.pythonscad.org/pictures/pythonscad-128.png</icon>
  <categories>
    <category>Graphics</category>
    <category>3DGraphics</category>
  </categories>
  <url type="homepage">https://www.pythonscad.org/</url>
  <url type="bugtracker">https://github.com/pythonscad/pythonscad/issues</url>
  <url type="faq">https://www.pythonscad.org/get_started/</url>
  <url type="help">https://www.pythonscad.org/tutorial/getting_started/</url>
  <url type="donation">https://www.pythonscad.org/contact/</url>
  <launchable type="desktop-id">org.pythonscad.pythonscad${SUFFIX_WITH_DASH}.desktop</launchable>
  <project_license>GPL-2.0-or-later</project_license>
  <description>
    <p>PythonSCAD is a script-based 3D modeling application with a full GUI. Write parametric, engineering-oriented models in Python, preview them live, and export to STL, 3MF, and other formats for 3D printing and manufacturing.</p>
    <p>Unlike artistic modeling tools such as Blender, PythonSCAD focuses on precise, repeatable CAD workflows driven by code. Solids are first-class values: compose models with Python, use pip packages, and iterate quickly with instant visual feedback in the 3D preview.</p>
    <p>PythonSCAD is also a rewarding way to learn programming — a few lines of Python can produce a model you can hold in your hand after 3D printing. OpenSCAD scripts remain supported alongside native Python.</p>
  </description>
  <provides>
    <mediatype>application/x-pythonscad</mediatype>
  </provides>
  <developer_name>The PythonSCAD and OpenSCAD Developers</developer_name>
